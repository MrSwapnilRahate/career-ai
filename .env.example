# ───────────────────────────────────────────────────────────────
# CareerAI Platform — Environment Variables
# Copy this file to .env and fill in your values
# ───────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/career-ai

# JWT Secrets (generate strong random strings)
JWT_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Google Gemini AI ──────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key
AI_PRO_MODEL=gemini-2.5-pro-preview-06-05
AI_FLASH_MODEL=gemini-2.5-flash-preview-05-20
AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_RETRIES=3

# ─── Stripe Payments ──────────────────────────────────────────
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Create products/prices in Stripe Dashboard, then paste IDs here:
STRIPE_PRICE_PRO=price_pro_monthly_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly_id

# Cloudinary
CLOUD_NAME=your-cloud-name
CLOUD_API_KEY=your-api-key
CLOUD_API_SECRET=your-api-secret

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
