{
  "name": "career-ai",
  "version": "3.0.0",
  "description": "CareerAI — AI-powered career intelligence platform with resume analysis, LinkedIn optimization, and professional photo generation",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client:install": "cd client && npm install",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "dev:all": "npm run dev & npm run client:dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "career-ai",
    "resume-analyzer",
    "ats-scoring",
    "linkedin-optimizer",
    "ai-photos",
    "gemini",
    "nodejs",
    "express",
    "react"
  ],
  "author": "Swapnil Rahate",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/genai": "^2.2.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.0.0",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.0.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.8.0",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "pdf-parse": "^1.1.1",
    "stripe": "^22.1.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
